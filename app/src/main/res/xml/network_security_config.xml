<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows cleartext (http) traffic — required because we intercept and
  optionally upgrade it to https ourselves in WebViewManager.
  In a production build you could tighten this to specific domains.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
