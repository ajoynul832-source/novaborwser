<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base application theme.
    -->
    <style name="Theme.NovaBrowser" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Colours (use @color resources to avoid AAPT reference errors) -->
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorPrimaryVariant">@color/accent_purple</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/accent_purple_light</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorBackground">@color/bg_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorError">@color/incognito_red</item>

        <!-- Status bar + nav bar -->
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- No title bar — we use our own Toolbar -->
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>

        <!-- Smooth window background -->
        <item name="android:windowBackground">@color/bg_primary</item>

        <!-- Ripple on dark surfaces (kept as literal alpha+color; optional: add to colors.xml) -->
        <item name="rippleColor">#337B2FBE</item>

        <!-- PopupMenu dark style -->
        <item name="popupMenuStyle">@style/NovaBrowser.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/NovaBrowser.PopupMenu</item>
    </style>

    <!-- Dark popup / overflow menu -->
    <style name="NovaBrowser.PopupMenu" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@color/bg_elevated</item>
    </style>

    <!-- Settings activity — same base, keeps ActionBar for Up navigation -->
    <style name="Theme.NovaBrowser.Settings" parent="Theme.NovaBrowser">
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">false</item>
        <item name="colorPrimary">@color/bg_surface</item>
        <item name="actionBarStyle">@style/NovaBrowser.ActionBar</item>
    </style>

    <style name="NovaBrowser.ActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/bg_surface</item>
        <item name="titleTextStyle">@style/NovaBrowser.ActionBar.Title</item>
    </style>

    <style name="NovaBrowser.ActionBar.Title" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/text_primary</item>
    </style>

</resources>
