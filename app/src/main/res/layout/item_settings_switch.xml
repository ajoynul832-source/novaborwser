<?xml version="1.0" encoding="utf-8"?>
<!--
  Reusable settings row: label + description on the left, Switch on the right.
  Override android:id on each <include> to get unique binding IDs.
  The actual Switch widget id is always @+id/setting_switch.
  Labels are set programmatically in SettingsActivity, or you can
  hardcode them per-row if you prefer static XML.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/setting_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:text="Setting" />

        <TextView
            android:id="@+id/setting_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#66FFFFFF"
            android:textSize="12sp"
            android:visibility="gone" />

    </LinearLayout>

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/setting_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:thumbTint="#7B2FBE"
        android:trackTint="#3D1D5E" />

</LinearLayout>
